#!/bin/sh
# Pre-commit hook — mirrors GitHub CI checks locally
# Go: goimports + go vet + go build + go test
# Frontend: tsc type check

set -e

STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

# --- Go checks ---
if [ -n "$STAGED_GO" ]; then
  echo "==> go: goimports"
  if command -v goimports >/dev/null 2>&1; then
    BAD=$(echo "$STAGED_GO" | xargs goimports -l 2>/dev/null)
    if [ -n "$BAD" ]; then
      echo "goimports formatting needed:"
      echo "$BAD"
      echo ""
      echo "Fix: goimports -w $BAD"
      exit 1
    fi
  fi

  echo "==> go: vet"
  go vet ./...

  echo "==> go: build"
  go build ./cmd/server/ ./cmd/mcp/

  echo "==> go: test"
  go test ./... -short -count=1
fi

# --- Frontend checks ---
if [ -n "$STAGED_TS" ]; then
  if [ -f web/package.json ]; then
    echo "==> frontend: tsc --noEmit"
    (cd web && npx tsc --noEmit)
  fi
fi

echo "==> pre-commit passed"
