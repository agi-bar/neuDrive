# Copy to `agenthub.env` for local Docker Compose:
#   cp agenthub.env.example agenthub.env
#   docker compose --env-file agenthub.env up
#
# Copy to `~/apps/agenthub/config/agenthub.env` for production deploy:
#   mkdir -p ~/apps/agenthub/config
#   cp agenthub.env.example ~/apps/agenthub/config/agenthub.env
#   ~/apps/agenthub/bin/deploy-main

# Shared PostgreSQL credentials.
POSTGRES_DB=agenthub
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

# App runtime configuration.
PORT=8080
JWT_SECRET=change-this-to-a-random-secret
VAULT_MASTER_KEY=generate-with-openssl-rand-hex-32
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Local defaults. For production, set these to your public domain.
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional overrides:
# DATABASE_URL=postgres://agenthub:change-this-postgres-password@localhost:5432/agenthub?sslmode=disable
# CLOUDFLARED_TUNNEL_TOKEN=
# AGENTHUB_CAPTURE_OAUTH=1
# AGENTHUB_CAPTURE_DIR=tmp/oauth-captures
