# Copy to `neudrive.env` for local Docker Compose:
#   cp neudrive.env.example neudrive.env
#   docker compose --env-file neudrive.env up
#
# Copy to `~/apps/neudrive/config/neudrive.env` for production deploy:
#   mkdir -p ~/apps/neudrive/config
#   cp neudrive.env.example ~/apps/neudrive/config/neudrive.env
#   ~/apps/neudrive/bin/deploy-main

# Shared PostgreSQL credentials.
POSTGRES_DB=neudrive
POSTGRES_USER=neudrive
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

# App runtime configuration.
PORT=8080
JWT_SECRET=change-this-to-a-random-secret
VAULT_MASTER_KEY=generate-with-openssl-rand-hex-32
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Local defaults. For production, set these to your public domain.
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional overrides:
# DATABASE_URL=postgres://neudrive:change-this-postgres-password@localhost:5432/neudrive?sslmode=disable
# CLOUDFLARED_TUNNEL_TOKEN=
# NEUDRIVE_CAPTURE_OAUTH=1
# NEUDRIVE_CAPTURE_DIR=tmp/oauth-captures
